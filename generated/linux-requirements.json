{
  "platform": "linux",
  "project": {
    "name": "orthotech_dev",
    "cpp_standard": 17,
    "python": "3.11"
  },
  "packages": [
    {
      "name": "cmake"
    },
    {
      "name": "ninja-build"
    },
    {
      "name": "build-essential"
    },
    {
      "name": "g++"
    },
    {
      "name": "make"
    },
    {
      "name": "pkg-config"
    },
    {
      "name": "git"
    },
    {
      "name": "libeigen3-dev"
    },
    {
      "name": "libboost-all-dev"
    },
    {
      "name": "libopencv-dev"
    },
    {
      "name": "libasio-dev"
    },
    {
      "name": "libfmt-dev"
    },
    {
      "name": "liburdfdom-dev"
    },
    {
      "name": "libssl-dev"
    },
    {
      "name": "libcurl4-openssl-dev"
    },
    {
      "name": "zlib1g-dev"
    }
  ],
  "vcpkg": [],
  "source": [
    {
      "name": "ur_rtde",
      "repo": "https://gitlab.com/sdurobotics/ur_rtde.git",
      "tag": "v1.5.5",
      "cmake_args": "-DPYTHON_BINDINGS=OFF -DRTDE_BUILD_EXAMPLES=OFF",
      "build_dir": "",
      "post_install": ""
    },
    {
      "name": "spdlog",
      "repo": "https://github.com/gabime/spdlog.git",
      "tag": "v1.14.1",
      "cmake_args": "-DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=OFF -DCMAKE_POSITION_INDEPENDENT_CODE=ON -DBUILD_TESTING=OFF -DSPDLOG_BUILD_EXAMPLE=OFF -DSPDLOG_BUILD_TESTS=OFF",
      "build_dir": "",
      "post_install": ""
    },
    {
      "name": "pinocchio",
      "repo": "https://github.com/stack-of-tasks/pinocchio.git",
      "tag": "v3.3.0",
      "post_checkout": "sed -i 's/cmake_minimum_required(VERSION .*)/cmake_minimum_required(VERSION 3.22)/g' CMakeLists.txt",
      "cmake_args": "-DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=OFF -DCMAKE_POSITION_INDEPENDENT_CODE=ON -DBUILD_WITH_AUTODIFF_SUPPORT=OFF -DBUILD_WITH_CASADI_SUPPORT=OFF -DBUILD_WITH_CODEGEN_SUPPORT=OFF -DBUILD_PYTHON_INTERFACE=OFF -DBUILD_UNIT_TESTS=OFF -DBUILD_EXAMPLES=OFF -DBUILD_BENCHMARK=OFF -DCMAKE_PREFIX_PATH=/opt/orthotech_dev  ",
      "build_dir": "",
      "post_install": ""
    },
    {
      "name": "BehaviorTree.CPP",
      "repo": "https://github.com/BehaviorTree/BehaviorTree.CPP.git",
      "tag": "4.9.0",
      "cmake_args": "-DCMAKE_BUILD_TYPE=RelWithDebInfo -DCMAKE_CXX_STANDARD=17 -DCMAKE_CXX_STANDARD_REQUIRED=ON -DCMAKE_POSITION_INDEPENDENT_CODE=ON -DBTCPP_SHARED_LIBS=OFF -DBUILD_TESTING=OFF -DBTCPP_EXAMPLES=OFF -DBTCPP_BUILD_TOOLS=OFF -DBTCPP_GROOT_INTERFACE=ON -DBTCPP_SQLITE_LOGGING=OFF -DUSE_VENDORED_TINYXML2=OFF -DUSE_VENDORED_CPPZMQ=OFF -DCMAKE_CXX_FLAGS=-D_GLIBCXX_USE_CXX11_ABI=1 -DCMAKE_PREFIX_PATH=/opt/orthotech_dev",
      "build_dir": "",
      "post_install": ""
    }
  ],
  "pip": [
    {
      "name": "pyyaml",
      "version": "6.0.1"
    },
    {
      "name": "numpy",
      "version": "1.26.4"
    },
    {
      "name": "requests",
      "version": "2.31.0"
    }
  ]
}
